# AI 教材精学老师 — 环境变量配置示例
# 复制本文件为 .env.local，然后填入真实值

# ============================================================
# AI 模型配置
# 格式: provider:model-name
# 示例:
#   anthropic:claude-sonnet-4-6    (production)
#   google:gemini-2.5-flash        (dev/test)
#   openai:deepseek-chat           (OpenAI-compatible, requires OPENAI_BASE_URL)
# ============================================================
AI_MODEL=google:gemini-2.5-flash

# ============================================================
# Provider API Keys
# 按需配置你实际使用的 provider
# ============================================================
ANTHROPIC_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=

# ============================================================
# PostgreSQL 数据库连接
# ============================================================
DATABASE_URL=postgresql://user:password@localhost:5432/textbook_teacher
