# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# database (local SQLite, contains user data)
/data/*.db
/data/*.db-shm
/data/*.db-wal

# user-uploaded PDFs (runtime test data; historical PDFs remain tracked)
/data/uploads/*.pdf

# typescript
*.tsbuildinfo
next-env.d.ts

# git worktrees (isolated milestone workspaces)
/.worktrees/

# CCB runtime session files
.ccb/.*-session

# CCB task ledger (runtime state, not committed)
.ccb/task-ledger.json

# Claude Code hook runtime state
.claude/.stop-count

# CCB inbox messages (runtime, not committed)
.ccb/inbox/**
!.ccb/inbox/*/
!.ccb/inbox/*/.gitkeep

# CCB ad-hoc smoke/debug scripts (contain hardcoded local paths)
.ccb/*.mjs
.ccb/*.sh
.ccb/*.json
.ccb/counters/
.ccb/history/
.ccb/precompact-saved-*

# Claude Code scheduled tasks runtime lock
.claude/scheduled_tasks.lock

# Superpowers runtime artifacts
.superpowers/
.claude/skills/**/scripts/.superpowers/

# MCP config (contains API keys)
.mcp.json
